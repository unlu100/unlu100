<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Yapay Zeka Vize Sınavı Not Sorgulama</title>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    body{
      font-family: Arial, sans-serif;
      background:#f4f4f4;
      padding:40px;
    }

    .container{
      max-width:500px;
      margin:auto;
      background:white;
      padding:25px;
      border-radius:10px;
      box-shadow:0 0 10px rgba(0,0,0,0.1);
    }

    input{
      width:100%;
      padding:10px;
      margin-top:10px;
      margin-bottom:15px;
      box-sizing:border-box;
    }

    button{
      width:100%;
      padding:12px;
      background:#0077cc;
      color:white;
      border:none;
      cursor:pointer;
      border-radius:5px;
    }

    button:hover{
      background:#005fa3;
    }

    .result{
      margin-top:20px;
      padding:15px;
      background:#eef;
      border-radius:5px;
    }

    .error{
      color:red;
      margin-top:15px;
    }
  </style>
</head>
<body>

<div class="container">

  <h2>Öğrenci Not Sorgulama</h2>

  <input type="text" id="ogrNo" placeholder="Öğrenci No">
  
  <input type="text" id="adSoyad" placeholder="AD SOYAD veya SOYAD AD">

  <button onclick="sorgula()">
    Sorgula
  </button>

  <div id="sonuc"></div>

</div>

<script>

  // BURAYI DEĞİŞTİR
  // const supabaseUrl = 'https://PROJE_ID.supabase.co';
  const supabaseUrl = "https://dumzxgwuzzuasdlqrytw.supabase.co";

  // BURAYI DEĞİŞTİR
  // const supabaseKey = 'ANON_PUBLIC_KEY';
  const supabaseKey = 'sb_publishable_rout-nyMOoH7Sm5YLzLhOA_2N9iHgdp';

  const supabaseClient = supabase.createClient(
    supabaseUrl,
    supabaseKey
  );

  const cevapAnahtari = {
    A: `
  	A kitapçığı açıklaması:
	Verdiğiniz şıkları gösteren dizide küçük/büyük harfler normalde doğru/yanlış gösterme amaçlıdır. Bunlarda sorun bulunması nedeniyle, hangi soruların doğru olduğunu gösteren rakamları dikkate alınız.
    `,
    
	B: `
	B kitapçığı açıklaması:
	Verdiğiniz şıkları gösteren dizide küçük/büyük harfler normalde doğru/yanlış gösterme amaçlıdır. Bunlarda sorun bulunması nedeniyle, hangi soruların doğru olduğunu gösteren rakamları dikkate alınız.
  };  
  
  async function sorgula(){

    const ogrNo = document
      .getElementById("ogrNo")
      .value
      .trim();

    const adSoyad = document
      .getElementById("adSoyad")
      .value
      .trim();

    const sonucDiv = document.getElementById("sonuc");

    sonucDiv.innerHTML = "Sorgulanıyor...";

    const { data, error } = await supabaseClient
      .from('vize_ypzeka_26')
      .select('*')
      .eq('No', Number(ogrNo))
      .ilike('adiSoyadi', adSoyad)
      .limit(1);

    if(error){
      sonucDiv.innerHTML =
        `<div class="error">
          Hata oluştu.
        </div>`;

      console.log(error);
      return;
    }

    if(data.length === 0){

      sonucDiv.innerHTML =
        `<div class="error">
          Kayıt bulunamadı.
        </div>`;

      return;
    }

    const ogr = data[0];
	// SAYACI ARTIR

	const yeniSayac = (ogr.sayac || 0) + 1;
	
	await supabaseClient
	  .from('vize_ypzeka_26')
	  .update({
	    sayac: yeniSayac
	  })
	  .eq('No', ogr.No);

    sonucDiv.innerHTML = `
      <div class="result">

        <h3>Sonuç</h3>

        <p><strong>Öğrenci No:</strong> ${ogr.No}</p>

        <p><strong>Ad Soyad:</strong> ${ogr.adiSoyadi}</p>

		<p><strong>Ad Soyad Notu:</strong> ${ogr.Aciklama}</p>

        <p><strong>Puan:</strong> ${ogr.Hesaplama}</p>

        <p><strong>Doğru Sayısı:</strong> ${ogr.dogru_sayi_asil}</p>

        <p><strong>Yanlış Sayısı:</strong> ${ogr.yanlis_sayi}</p>

        <p><strong>Verdiğiniz Cevaplar:</strong> ${ogr.Konu1Cev}</p>

        <p><strong>Doğrular1:</strong> ${ogr.dogrular_liste2}</p>

        <p><strong>Yanlışlar:</strong> ${ogr.yanlislar_liste2}</p>

		<p><strong>Toplam Görüntülenme:</strong> ${yeniSayac}</p>

		<p><strong>Kitapçık:</strong> ${ogr.kitapcik}</p>

		<p><strong>Cevap Anahtarı:</strong></p>
		
			<div style="
			  background:#f7f7f7;
			  padding:10px;
			  border-radius:5px;
			  white-space:pre-wrap;
			  font-family:monospace;
			">
			${cevapAnahtari[ogr.kitapcik]}
		
		      </div>
    `;
  }

</script>

</body>
</html>
